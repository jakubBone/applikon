# ===========================================
# Applikon - Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# For production, create a separate .env.prod:
#   docker-compose --env-file .env.prod up -d
#
# Note: the frontend has its own .env.example in applikon-frontend/

# -------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------
POSTGRES_DB=applikon_db
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_password_here

# Backend datasource — required when running the backend locally (./mvnw spring-boot:run).
# When running via docker-compose these are built automatically from POSTGRES_* above.
DATABASE_URL=jdbc:postgresql://localhost:5432/applikon_db
DATABASE_USERNAME=your_db_user
DATABASE_PASSWORD=your_secure_password_here

# -------------------------------------------
# Backend (Spring Boot)
# -------------------------------------------
# Active profile: local, dev, prod
# Dev (docker-compose locally): dev
# Production (Hetzner): prod
SPRING_PROFILES_ACTIVE=local

# CORS — comma-separated allowed origins
# Dev:  http://localhost:3000,http://localhost:5173
# Prod: https://your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173


# Frontend URL — used for OAuth2 redirect after successful Google login
# Dev:  http://localhost:3000
# Prod: https://your-domain.com
FRONTEND_URL=http://localhost:3000
VITE_USE_BACKEND=true

# -------------------------------------------
# Google OAuth2 (REQUIRED — create credentials at https://console.cloud.google.com/)
# -------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -------------------------------------------
# Admin key — protects admin-only endpoints
# Generate with: openssl rand -base64 32
# -------------------------------------------
ADMIN_KEY=

# -------------------------------------------
# HMAC secret — used to sign refresh token hashes stored in the DB.
# More secure than plain SHA-256: the hash depends on this server-side secret,
# so even if the DB leaks, an attacker cannot verify tokens without knowing it.
# WARNING: changing this value invalidates all existing refresh tokens (users must re-login).
# Generate with: openssl rand -base64 32
# -------------------------------------------
APP_TOKEN_HMAC_SECRET=

# -------------------------------------------
# Frontend build args — baked into the JS bundle at docker-compose build time
# Prod: https://your-domain.com/api
# -------------------------------------------
VITE_API_URL=http://localhost:8080/api

# -------------------------------------------
# JWT (optional — defaults shown)
# -------------------------------------------
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# -------------------------------------------
# File uploads (optional — default shown)
# -------------------------------------------
UPLOAD_DIR=uploads/cv
